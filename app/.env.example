# X (Twitter) OAuth 2.0
AUTH_TWITTER_ID=your_twitter_client_id
AUTH_TWITTER_SECRET=your_twitter_client_secret
AUTH_SECRET=generate_with_openssl_rand_base64_32

# Grok API
GROK_API_KEY=your_grok_api_key

# Anthropic API (for server-side usage if needed)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Encryption key for storing user API keys
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# Supabase (optional — for persistent user storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
